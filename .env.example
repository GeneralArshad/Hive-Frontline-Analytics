# ── Database (auto-set by Railway when you add a PostgreSQL service) ──
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Session ──────────────────────────────────────────────────────────
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── Dashboard Login ───────────────────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your-secure-password-here

# ── Hive Frontline API ────────────────────────────────────────────────
HIVE_API_URL=https://hive-frontline-backend.com
HIVE_ORG_ID=69bfddb4be37f4864f67ca8a
HIVE_USERNAME=superadmin
HIVE_PASSWORD=SuperAdmin@123

# ── App ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
